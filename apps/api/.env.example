DATABASE_URL=postgresql+psycopg2://buildlaw:buildlaw@localhost:5432/buildlaw
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=buildlaw-documents
S3_REGION=us-east-1
# Публичный URL для клиента (presigned). Для MinIO на хосте:
S3_PUBLIC_ENDPOINT_URL=http://127.0.0.1:9000

API_V1_PREFIX=/v1
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Supabase Storage (опционально; если задать SUPABASE_URL — будет использован вместо S3/MinIO)
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...
# SUPABASE_STORAGE_BUCKET=documents
