### BuildLaw AI - VPS production example
### Copy to `.env.vps` on the server and edit values.

# Public domains (used by reverse proxy)
PUBLIC_WEB_DOMAIN=app.example.ru
PUBLIC_API_DOMAIN=api.example.ru

# Secrets
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
POSTGRES_PASSWORD=CHANGE_ME_STRONG
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG

# Storage bucket
S3_BUCKET_NAME=buildlaw-documents

